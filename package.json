  },
  "engines": {
    "node": ">=15.x",
    "npm": ">=6.x",
    "yarn": ">=1.21.3"
  },
  "browserslist": [],
  "renovate": {
    "extends": ["bliss"],
    "baseBranches": ["next"]
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn checks"
    }
  }
}
