    "minidenticons": "1.0.3",
    "qrcode.react": "3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-minimal-pie-chart": "8.3.0",
    "react-redux": "^8.0.2",
    "react-select": "^5.4.0",
